{
  "Allocator": {
    "Backend": "LocalProcess",
    "PortStart": 19000,
    "PortEnd": 19099,
    "RegistrationTimeoutSeconds": 30,
    "HeartbeatTimeoutSeconds": 15,
    "HeartbeatIntervalSeconds": 3,
    "MonitorIntervalMilliseconds": 500,
    "DrainGraceSeconds": 3,
    "AdvertisedIp": "127.0.0.1",
    "GameServerExecutablePath": "",
    "GameServerWorkingDirectory": "",
    "GameServerPrefixArguments": [],
    "MatchResultOutboxDirectory": "match-result-outbox",
    "StateFilePath": "allocator-state/instances.json",
    "StateCheckpointSeconds": 5,
    "FailureNotificationRetrySeconds": 5,
    "MatchResultRecoveryDelaySeconds": 15,
    "LobbyInternalUrl": "http://127.0.0.1:18080",
    "ServiceToken": "",
    "LobbyCallbackToken": "",
    "JoinTicketSigningKey": "",
    "Agones": {
      "Namespace": "guiyang-mahjong",
      "FleetName": "guiyang-mahjong",
      "ApiServer": "https://kubernetes.default.svc",
      "ServiceAccountTokenPath": "/var/run/secrets/kubernetes.io/serviceaccount/token",
      "ServiceAccountCaPath": "/var/run/secrets/kubernetes.io/serviceaccount/ca.crt",
      "RequestTimeoutSeconds": 10
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
